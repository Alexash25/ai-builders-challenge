# CreatorLens — environment variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------

# Directory where uploaded videos and pipeline outputs are stored.
# Use a relative path (e.g. ./uploads) so the app is portable.
UPLOAD_DIR=./uploads

# Maximum allowed video upload size in bytes. Default is 500 MB.
MAX_UPLOAD_BYTES=524288000

# ---------------------------------------------------------------------------
# IBM watsonx.ai credentials
# ---------------------------------------------------------------------------

# Your IBM Cloud API key. Generate one at cloud.ibm.com → Manage → Access.
WATSONX_API_KEY=

# The watsonx.ai project ID. Found in your project settings on dataplatform.cloud.ibm.com.
WATSONX_PROJECT_ID=

# watsonx.ai regional endpoint. Default is us-south.
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Granite model identifier. Change only if you switch to a different Granite version.
GRANITE_MODEL_ID=ibm/granite-3-3-8b-instruct

# ---------------------------------------------------------------------------
# Dev flags
# ---------------------------------------------------------------------------

# Set to true to skip all real IBM API calls and return mock fixtures instead.
# Safe to leave true during local development — no credentials required.
USE_MOCK_AI=true

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------

# The frontend origin that the backend allows cross-origin requests from.
# For local development this is the Next.js dev server.
FRONTEND_ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# System dependencies (not env variables — document here for new devs)
# ---------------------------------------------------------------------------
# FFmpeg and ffprobe must be installed and available on PATH.
# Install on Windows: https://ffmpeg.org/download.html
# Install on Mac:     brew install ffmpeg
# Install on Linux:   sudo apt install ffmpeg
